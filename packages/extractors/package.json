{
  "name": "@mappamind_/extractors",
  "version": "0.0.0",
  "description": "Tree-sitter fact extraction for Mappamind (17 languages).",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.js",
    "!dist/**/*.test.d.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mappamind/mappamind.git",
    "directory": "packages/extractors"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "web-tree-sitter": "^0.25.0",
    "tree-sitter-wasms": "^0.1.11"
  }
}
